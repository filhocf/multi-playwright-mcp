{
  "name": "@filhocf/multi-playwright-mcp",
  "version": "1.1.0",
  "description": "Multi-session wrapper around @playwright/mcp — run multiple isolated browsers via a single MCP server",
  "main": "dist/index.js",
  "bin": {
    "multi-playwright-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc && node -e \"const fs=require('fs');const f='dist/index.js';fs.writeFileSync(f,'#!/usr/bin/env node\\n'+fs.readFileSync(f));fs.chmodSync(f,0o755)\"",
    "start": "node dist/index.js",
    "dev": "tsc --watch"
  },
  "keywords": [
    "mcp",
    "playwright",
    "browser",
    "automation",
    "multi-session"
  ],
  "author": "Claudio Ferreira Filho <filhocf@gmail.com>",
  "license": "MIT",
  "type": "commonjs",
  "repository": {
    "type": "git",
    "url": "https://github.com/filhocf/multi-playwright-mcp.git"
  },
  "files": [
    "dist/**/*.js",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@playwright/mcp": "^0.0.68"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "typescript": "^5.9.3"
  }
}
